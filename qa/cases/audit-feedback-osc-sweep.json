{
  "id": "audit-feedback-osc-sweep",
  "title": "Feedback sweep on osc source",
  "source": {
    "kind": "osc"
  },
  "transport": {
    "start": true,
    "settleMs": 1200
  },
  "recording": {
    "filename": "audit-feedback-osc-sweep",
    "tailMs": 700
  },
  "expectations": {
    "sourceKind": "osc",
    "audioActive": true,
    "allowConsoleErrors": ["favicon.ico"]
  },
  "audit": {
    "family": "feedback-composition",
    "operator": "feedback",
    "kind": "sweep",
    "path": "operator-regression",
    "expectedVideo": [
      "raising feedback should increase visible frame persistence without collapsing into blank or frozen output",
      "higher delay settings should preserve motion continuity rather than producing unstable flashes"
    ],
    "expectedAudio": [
      "raising feedback should deepen the freeze-smear / feedback-PM texture without runaway gain",
      "longer delay should widen the recirculating smear while keeping the tone intelligible"
    ],
    "manualChecks": [
      "Does persistence increase in a controlled way across the sweep?",
      "Does the audio stay musically usable rather than turning harsh, muddy, or pinned?"
    ]
  },
  "steps": [
    {
      "type": "set-source-param",
      "paramId": "frequency",
      "value": 110,
      "screenshot": "feedback-sweep-frequency-110"
    },
    {
      "type": "set-operator-param",
      "op": "feedback",
      "paramId": "feedback",
      "value": 0.2,
      "screenshot": "feedback-020"
    },
    {
      "type": "wait",
      "ms": 350,
      "screenshot": "feedback-020-hold"
    },
    {
      "type": "set-operator-param",
      "op": "feedback",
      "paramId": "feedback",
      "value": 0.55,
      "screenshot": "feedback-055"
    },
    {
      "type": "set-operator-param",
      "op": "feedback",
      "paramId": "delayTime",
      "value": 0.3,
      "screenshot": "feedback-delay-030"
    },
    {
      "type": "wait",
      "ms": 500,
      "screenshot": "feedback-055-hold"
    }
  ]
}
