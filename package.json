{
  "name": "av-synth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser-based video-first AV effects app with mathematically coupled audio and video domains. Hydra-inspired.",
  "scripts": {
    "dev": "vite",
    "dev:http": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "preview:http": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . && prettier --check .",
    "qa:smoke": "playwright test -c qa/playwright.config.ts",
    "qa:smoke:preview": "npm run build && PLAYWRIGHT_SERVER_MODE=preview playwright test -c qa/playwright.config.ts",
    "qa:smoke:external": "PLAYWRIGHT_SERVER_MODE=external playwright test -c qa/playwright.config.ts",
    "qa:cases": "playwright test -c qa/playwright.config.ts",
    "qa:cases:preview": "npm run build && PLAYWRIGHT_SERVER_MODE=preview playwright test -c qa/playwright.config.ts",
    "qa:cases:external": "PLAYWRIGHT_SERVER_MODE=external playwright test -c qa/playwright.config.ts",
    "qa:analyze": "node qa/analyze.js",
    "qa:references:sync": "node qa/reference-sync.mjs",
    "qa:audit:cases": "playwright test -c qa/playwright.config.ts -g audit-",
    "qa:audit:cases:preview": "npm run build && PLAYWRIGHT_SERVER_MODE=preview playwright test -c qa/playwright.config.ts -g audit-",
    "qa:audit:cases:external": "PLAYWRIGHT_SERVER_MODE=external playwright test -c qa/playwright.config.ts -g audit-",
    "qa:audit:analyze": "node qa/analyze.js audit-",
    "qa:audit": "npm run qa:audit:cases && npm run qa:audit:analyze",
    "qa:full": "npm run qa:smoke && npm run qa:analyze",
    "qa:audit:ci": "npm run check && npm run lint && npm run test:run && npm run build && npm run qa:audit",
    "qa:ci": "npm run check && npm run lint && npm run test:run && npm run build && npm run qa:full",
    "qa:granulator:listening": "node qa/scripts/granulator-listening-pack.mjs",
    "qa:granulator:latency": "playwright test -c qa/playwright.config.ts qa/e2e/d4-midi-latency-proxy.spec.ts",
    "qa:report": "playwright show-report qa/results/playwright/report",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
